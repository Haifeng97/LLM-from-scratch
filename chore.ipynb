   "source": [
    "import torch\n",
    "\n",
    "B = 2\n",
    "T = 4\n",
    "C = 6\n",
    "\n",
    "x = torch.randn(B, T, C)\n",
    "\n",
    "print(\"x:\", x.shape)\n",
    "\n",
    "q = x\n",
    "k = x\n",
    "\n",
    "scores = q @ k.transpose(-2, -1)\n",
    "\n",
    "print(\"k transpose:\", k.transpose(-2, -1).shape)\n",
    "print(\"scores:\", scores.shape)"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
